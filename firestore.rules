rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper utilities
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(studentId) {
      return isSignedIn() && request.auth.uid == studentId;
    }

    // Basic validator to check schema types and ownership constraint
    function isValidStudent(data) {
      return data.uid == request.auth.uid 
        && data.email is string 
        && data.name is string 
        && (data.level == 'Beginner' || data.level == 'Intermediate' || data.level == 'Advanced')
        && data.points is int;
    }

    // Rules for students collection
    match /students/{studentId} {
      allow read: if isOwner(studentId);
      allow create: if isOwner(studentId) && isValidStudent(request.resource.data);
      allow update: if isOwner(studentId) && isValidStudent(request.resource.data);
      allow delete: if false; // Deletion is not allowed from client SDKs to protect progress
    }
  }
}
