rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for students collection
    match /students/{studentId} {
      allow read, write: if request.auth != null && request.auth.uid == studentId;
    }
  }
}
